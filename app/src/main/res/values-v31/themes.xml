<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.Kairos" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>

    <style name="Theme.Kairos.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/kairos_amber</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.Kairos</item>
    </style>
</resources>
